  "devDependencies": {
    "@ownclouders/extension-sdk": "^12.4.2",
    "@ownclouders/web-test-helpers": "^12.4.2",
    "@playwright/test": "^1.61.1",
    "@vitejs/plugin-vue": "^5.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vitest": "^1.5.0"
  }
