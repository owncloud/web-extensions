{
  "name": "photo-addon",
  "version": "0.2.0",
  "private": true,
  "description": "Photo gallery extension for ownCloud with timeline view, EXIF metadata, and map display",
  "license": "AGPL-3.0",
  "type": "module",
  "scripts": {
    "build": "pnpm vite build",
    "build:w": "pnpm vite build --watch --mode development",
    "check:types": "vue-tsc --noEmit",
    "test:unit": "NODE_OPTIONS=--unhandled-rejections=throw vitest",
    "test:e2e": "pnpm playwright test"
  },
  "dependencies": {
    "@ownclouders/web-client": "^12.3.2",
    "@ownclouders/web-pkg": "^12.3.2",
    "leaflet": "^1.9.4"
  },
  "devDependencies": {
    "@ownclouders/extension-sdk": "^12.3.2",
    "@ownclouders/web-test-helpers": "^12.3.2",
    "@types/leaflet": "^1.9.21",
    "sass-embedded": "^1.99.0",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7",
    "vue3-gettext": "^2.4.0"
  }
}
