  },
  "dependencies": {
    "pdfjs-dist": "^6.1.200",
    "vue3-gettext": "^2.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@ownclouders/eslint-config": "12.5.0",
    "@ownclouders/extension-sdk": "12.5.0",
    "@ownclouders/prettier-config": "0.0.1",
    "@ownclouders/tsconfig": "0.0.6",
    "@ownclouders/web-client": "^12.5.0",
    "@ownclouders/web-pkg": "^12.5.0",
    "@types/node": "22.19.19",
    "@vue/test-utils": "^2.4.6",
    "eslint": "9.39.4",
    "happy-dom": "^20.11.0",
    "prettier": "3.9.5",
    "ts-node": "^10.9.2",
    "typescript": "6.0.3",
    "vite": "7.2.2",
    "vitest": "4.1.10",
    "vue": "^3.5.40",
    "vue-router": "^5.2.0",
    "vue-tsc": "3.3.7"
  },
  "packageManager": "pnpm@10.34.1"
